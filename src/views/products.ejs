<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Product Management</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <h1>Product Management</h1>

    <% if (typeof message !== 'undefined' && message) { %>
      <div class="alert success"><%= message %></div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert error"><%= error %></div>
    <% } %>

    <div class="top-actions">
      <a class="btn" href="/seed-manufacturers">Seed Manufacturers</a>
    </div>

    <div class="section-card">
      <h2>Add Product</h2>

      <form action="/products/add" method="POST">
        <div class="form-grid">
          <div class="form-group">
            <label for="Id">Product Id</label>
            <input type="number" name="Id" id="Id" placeholder="Enter product id" required>
          </div>

          <div class="form-group">
            <label for="Name">Product Name</label>
            <input type="text" name="Name" id="Name" placeholder="Enter product name" required>
          </div>

          <div class="form-group">
            <label for="Quantity">Quantity</label>
            <input type="number" name="Quantity" id="Quantity" placeholder="Enter quantity" required>
          </div>

          <div class="form-group">
            <label for="Price">Price</label>
            <input type="number" step="0.01" name="Price" id="Price" placeholder="Enter price" required>
          </div>

          <div class="form-group">
            <label for="Size">Size</label>
            <select name="Size" id="Size" required>
              <option value="">Select Size</option>
              <option value="S">S</option>
              <option value="M">M</option>
              <option value="L">L</option>
              <option value="XL">XL</option>
            </select>
          </div>

          <div class="form-group">
            <label for="Status">Status</label>
            <select name="Status" id="Status" required>
              <option value="">Select Status</option>
              <option value="true">true</option>
              <option value="false">false</option>
            </select>
          </div>

          <div class="form-group">
            <label for="ExpirationDate">Expiration Date</label>
            <input type="date" name="ExpirationDate" id="ExpirationDate" required>
          </div>

          <div class="form-group">
            <label for="ManufacturerId">Manufacturer</label>
            <select name="ManufacturerId" id="ManufacturerId" required>
              <option value="">Select Manufacturer</option>
              <% if (typeof manufacturers !== 'undefined' && manufacturers.length > 0) { %>
                <% manufacturers.forEach(m => { %>
                  <option value="<%= m.Id %>"><%= m.Id %> - <%= m.Name %></option>
                <% }) %>
              <% } %>
            </select>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit">Add Product</button>
        </div>
      </form>
    </div>

    <div class="section-card">
      <h2>Search / Filter</h2>

      <form action="/" method="GET">
        <div class="filter-bar">
          <input
            type="text"
            name="name"
            placeholder="Search by name"
            value="<%= (typeof query !== 'undefined' && query.name) ? query.name : '' %>"
          >

          <select name="size">
            <option value="">All Sizes</option>
            <option value="S" <%= query && query.size === 'S' ? 'selected' : '' %>>S</option>
            <option value="M" <%= query && query.size === 'M' ? 'selected' : '' %>>M</option>
            <option value="L" <%= query && query.size === 'L' ? 'selected' : '' %>>L</option>
            <option value="XL" <%= query && query.size === 'XL' ? 'selected' : '' %>>XL</option>
          </select>

          <select name="status">
            <option value="">All Status</option>
            <option value="true" <%= query && query.status === 'true' ? 'selected' : '' %>>true</option>
            <option value="false" <%= query && query.status === 'false' ? 'selected' : '' %>>false</option>
          </select>

          <select name="manufacturerId">
            <option value="">All Manufacturers</option>
            <% if (typeof manufacturers !== 'undefined' && manufacturers.length > 0) { %>
              <% manufacturers.forEach(m => { %>
                <option
                  value="<%= m.Id %>"
                  <%= query && String(query.manufacturerId) === String(m.Id) ? 'selected' : '' %>>
                  <%= m.Name %>
                </option>
              <% }) %>
            <% } %>
          </select>

          <button type="submit">Filter</button>
        </div>
      </form>
    </div>

    <div class="section-card">
      <h2>Product List</h2>

      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Id</th>
              <th>Name</th>
              <th>Quantity</th>
              <th>Price</th>
              <th>Size</th>
              <th>Status</th>
              <th>Expiration Date</th>
              <th>Manufacturer Id</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (typeof products !== 'undefined' && products.length > 0) { %>
              <% products.forEach(product => { %>
                <tr>
                  <td><%= product.Id %></td>
                  <td><%= product.Name %></td>
                  <td><%= product.Quantity %></td>
                  <td><%= product.Price %></td>
                  <td><%= product.Size %></td>
                  <td>
                    <% if (product.Status === true) { %>
                      <span class="badge active">true</span>
                    <% } else { %>
                      <span class="badge inactive">false</span>
                    <% } %>
                  </td>
                  <td>
                    <%= product.ExpirationDate ? new Date(product.ExpirationDate).toLocaleDateString() : '' %>
                  </td>
                  <td><%= product.ManufacturerId %></td>
                  <td>
                    <div class="actions">
                      <a class="btn btn-secondary" href="/products/edit/<%= product._id %>">Edit</a>
                      <a class="btn btn-danger" href="/products/delete/<%= product._id %>" onclick="return confirm('Are you sure to delete this product?')">Delete</a>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="9" class="empty-state">No products found</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <p class="small-text">Large Data Management with MongoDB - Product Store Assignment</p>
    </div>
  </div>
</body>
</html>